{
  "name": "@chronus/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "build": "bun build src/index.ts --outdir ./dist --target bun --sourcemap --external @node-rs/argon2 --external bcrypt",
    "postbuild": "cp -r node_modules/@node-rs dist/ && cp -r node_modules/bcrypt dist/ 2>/dev/null || true",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:integration": "vitest --run src/modules/**/__tests__/integration/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@chronus/shared": "workspace:*",
    "@bull-board/api": "^6.16.4",
    "@bull-board/elysia": "^6.16.4",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.1.6",
    "@hookform/resolvers": "^5.2.2",
    "@node-rs/argon2": "^2.0.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/nodemailer": "^7.0.9",
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.4.2",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.1.29",
    "elysiajs-helmet": "^1.0.4",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.4",
    "uuid": "^13.0.0",
    "vitest": "^4.0.17",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/mime-types": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "bun-types": "^1.3.8",
    "drizzle-kit": "^0.29.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.2.5",
    "typescript": "5.5"
  }
}
